{
  "name": "kiwoom-rest-api",
  "version": "0.2.0",
  "description": "Kiwoom Securities REST API client library + MCP server",
  "license": "MPL-2.0",
  "homepage": "https://github.com/KKimj/Kiwoom-REST-API",
  "repository": {
    "type": "git",
    "url": "https://github.com/KKimj/Kiwoom-REST-API.git",
    "directory": "packages/typescript"
  },
  "keywords": [
    "kiwoom",
    "mcp",
    "rest-api",
    "stock",
    "korea",
    "trading"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "kiwoom-rest-api": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "python3 ../../build/typescript/generate.py",
    "prepare": "npm run build",
    "lint": "eslint src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=18"
  }
}
